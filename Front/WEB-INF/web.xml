<web-app xmlns="http://jcp.org"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://jcp.org http://jcp.org/web-app_4_0.xsd"
         version="4.0">

    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <include-prelude>/WEB-INF/jsp/prelude.jspf</include-prelude>
        </jsp-property-group>
    </jsp-config>

</web-app>
